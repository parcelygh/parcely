{
  "name": "@postalservice/auth-redirect",
  "version": "0.1.0",
  "description": "Browser-side login-redirect interceptor for postalservice. Redirects on 401/403 with optional return_to preservation and cooldown debounce.",
  "license": "MIT",
  "keywords": [
    "postalservice",
    "auth",
    "redirect",
    "login",
    "interceptor",
    "http",
    "browser"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "postalservice": "workspace:*"
  },
  "devDependencies": {
    "postalservice": "workspace:*",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^3.2.1"
  }
}
